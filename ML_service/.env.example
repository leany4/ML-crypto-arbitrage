# Внешние порты Docker Compose.
ML_PORT=8080
DASHBOARD_PORT=3000
SIM_PORT=8090

# auto использует CUDA при наличии GPU, cpu принудительно оставляет Torch на CPU.
ML_DEVICE=auto
NVIDIA_VISIBLE_DEVICES=all
ML_LOG_LEVEL=INFO

# Во время replay свечи присылает market_simulator, поэтому провайдер отключён.
ML_OHLCV_MODE=disabled
ML_OHLCV_PATH=/replay/ohlcv_raw.parquet

# memory не пишет данные на диск; sqlite сохраняет paper-историю между рестартами.
ML_PAPER_STORE=memory

# Параметры исторического replay.
SIM_DEFAULT_SPEED=1
SIM_DEFAULT_DURATION_SECONDS=900
